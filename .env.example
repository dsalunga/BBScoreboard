# PostgreSQL default profile
POSTGRES_DB=bbscoreboard
POSTGRES_USER=bbadmin
POSTGRES_PASSWORD=<set-postgres-password>

# Bootstrap admin (used by DatabaseSeeder on first run)
BOOTSTRAP_ADMIN_EMAIL=<set-admin-email>
BOOTSTRAP_ADMIN_PASSWORD=<set-admin-password>

# SQL Server profile (optional)
MSSQL_DB=BBScoreboard
MSSQL_SA_PASSWORD=<set-sqlserver-sa-password>
