@page
@{
    ViewData["Title"] = "Register Service";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <h2>External Registration</h2>
        <div class="alert alert-info">
            External registration services were retired in the .NET 10 migration.
            Use local email/password registration instead.
        </div>
        <a asp-page="/Account/Register" class="btn btn-primary">Go to Register</a>
    </div>
</div>
