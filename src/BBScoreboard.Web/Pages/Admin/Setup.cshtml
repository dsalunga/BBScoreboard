@page
@model BBScoreboard.Web.Pages.Admin.SetupModel
@{
    ViewData["Title"] = "Settings";
}

<h3>Settings</h3>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<form method="post" class="col-md-6">
    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" name="enableTimer" value="true" @(Model.EnableTimer ? "checked" : "") />
        <label class="form-check-label">Enable Timer</label>
    </div>
    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" name="showAllActions" value="true" @(Model.ShowAllActions ? "checked" : "") />
        <label class="form-check-label">Show All Actions</label>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>

<hr class="my-4" />

<h5>Quick Demo Setup</h5>
<p class="text-muted">Create a full demo season, two teams, players, and one game you can start/play immediately.</p>

<form method="post" asp-page-handler="CreateDemo">
    <button type="submit" class="btn btn-success">Create Demo Game Setup</button>
    @if (Model.DemoGameId.HasValue)
    {
        <a asp-page="/Gameplay/Manager" asp-route-id="@Model.DemoGameId.Value" class="btn btn-outline-primary ms-2">Open Manager</a>
        <a asp-page="/Gameplay/Stats" asp-route-id="@Model.DemoGameId.Value" class="btn btn-outline-secondary ms-2">Open Stats</a>
    }
</form>
