@page
@model BBScoreboard.Web.Pages.Admin.SetupModel
@{
    ViewData["Title"] = "Settings";
}

<h3>Settings</h3>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<form method="post" class="col-md-6">
    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" name="enableTimer" value="true" @(Model.EnableTimer ? "checked" : "") />
        <label class="form-check-label">Enable Timer</label>
    </div>
    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" name="showAllActions" value="true" @(Model.ShowAllActions ? "checked" : "") />
        <label class="form-check-label">Show All Actions</label>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>
