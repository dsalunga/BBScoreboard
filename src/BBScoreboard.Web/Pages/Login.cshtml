@page
@model BBScoreboard.Web.Pages.LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <h2>Sign In</h2>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-control" required />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Password</label>
                <input asp-for="Input.Password" type="password" class="form-control" required />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Sign In</button>
        </form>
        <div class="mt-3">
            <a asp-page="/Account/Register">Register</a> |
            <a asp-page="/Account/ForgotPassword">Forgot Password?</a>
        </div>
    </div>
</div>
