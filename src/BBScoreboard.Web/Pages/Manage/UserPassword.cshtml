@page "{id:int}"
@model BBScoreboard.Web.Pages.Manage.UserPasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<h3>Change Password — @Model.AppUser?.Email</h3>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<form method="post" class="col-md-6">
    <input type="hidden" name="id" value="@Model.AppUser!.Id" />
    <div class="mb-3">
        <label class="form-label">New Password</label>
        <input type="password" name="newPassword" class="form-control" required minlength="6" />
    </div>
    <div class="mb-3">
        <label class="form-label">Confirm Password</label>
        <input type="password" name="confirmPassword" class="form-control" required minlength="6" />
    </div>
    <button type="submit" class="btn btn-primary">Change Password</button>
    <a asp-page="Users" class="btn btn-secondary">Cancel</a>
</form>
