@page "{id:int}"
@model BBScoreboard.Web.Pages.Manage.TeamEntryModel
@{
    ViewData["Title"] = "Edit Team";
}

<h3>Edit Team</h3>

<form method="post" class="col-md-6">
    <input type="hidden" name="id" value="@Model.Team!.Id" />
    <div class="mb-3">
        <label class="form-label">Name</label>
        <input type="text" name="name" class="form-control" value="@Model.Team.Name" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Color</label>
        <input type="color" name="teamColor" class="form-control form-control-color" value="@Model.Team.TeamColor" />
    </div>
    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" name="active" value="true" @(Model.Team.Active ? "checked" : "") />
        <label class="form-check-label">Active</label>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-page="Teams" class="btn btn-secondary">Cancel</a>
</form>
