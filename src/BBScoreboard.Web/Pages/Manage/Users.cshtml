@page
@model BBScoreboard.Web.Pages.Manage.UsersModel
@{
    ViewData["Title"] = "Manage Users";
}

<h3>Users</h3>

<a asp-page="UserEntry" class="btn btn-primary mb-3">Add User</a>

<table class="table table-striped">
    <thead><tr><th>Email</th><th>Name</th><th>Access</th><th></th></tr></thead>
    <tbody>
        @foreach (var u in Model.UserList)
        {
            <tr>
                <td>@u.Email</td>
                <td>@u.FirstName @u.LastName</td>
                <td>@u.Access</td>
                <td>
                    <a asp-page="UserEntry" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-page="UserPassword" asp-route-id="@u.Id" class="btn btn-sm btn-outline-warning">Password</a>
                    @if (u.Id != Model.CurrentUserId)
                    {
                        <form method="post" asp-page-handler="Delete" class="d-inline">
                            <input type="hidden" name="id" value="@u.Id" />
                            <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this user?')">Delete</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
